<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.OnboardingPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#3B3532}">
    <Grid>
        <!-- CarouselView for onboarding -->
        <CarouselView x:Name="OnboardingCarousel"
                      IndicatorView="OnboardingIndicators"
                      ItemsSource="{Binding OnboardingItems}"
                      VerticalOptions="CenterAndExpand"
                      HorizontalOptions="FillAndExpand">
            <CarouselView.ItemTemplate>
                <DataTemplate>
                    <Frame CornerRadius="32"
                           Margin="24,40"
                           Padding="0"
                           HasShadow="False"
                           HeightRequest="600"
                           VerticalOptions="Center"
                           BackgroundColor="#FFF6E0">
                        <Grid RowDefinitions="*,Auto,Auto,Auto,Auto" Padding="32,32,32,24">
                            <Image Source="{Binding Image}" HeightRequest="180" Aspect="AspectFit" Grid.Row="0" HorizontalOptions="Center" />
                            <Label Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   FontSize="28"
                                   TextColor="#222"
                                   HorizontalOptions="Start"
                                   Margin="0,24,0,0"
                                   Grid.Row="1" />
                            <Label Text="{Binding Description}"
								   HorizontalTextAlignment="Start"
                                   FontSize="16"
                                   TextColor="#444"
                                   HorizontalOptions="Center"
                                   Margin="0,8,0,0"
                                   Grid.Row="2" />
                            <IndicatorView x:Name="InnerIndicators"
                                           IndicatorColor="#C4C4C4"
                                           SelectedIndicatorColor="#222"
                                           HorizontalOptions="Center"
                                           Margin="0,24,0,0"
                                           Grid.Row="3"
                                           IsVisible="False" />
                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,24,0,0">
                                <Button Text="SKIP"
                                        BackgroundColor="Transparent"
                                        TextColor="#222"
                                        FontAttributes="Bold"
                                        Clicked="OnSkipClicked"
                                        HorizontalOptions="Start"
                                        Padding="8,0"
                                        />
                                <Button x:Name="NextButton"
                                        Text="{Binding ButtonText}"
                                        BackgroundColor="{StaticResource AppPrimaryColor}"
                                        TextColor="{StaticResource AppTextDarkColor}"
                                        FontAttributes="Bold"
                                        CornerRadius="24"
                                        HeightRequest="48"
                                        WidthRequest="100"
                                        Command="{Binding ButtonCommand}"
                                        HorizontalOptions="End"
                                        />
                            </Grid>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>
        <IndicatorView x:Name="OnboardingIndicators"
                       IndicatorColor="{AppThemeBinding Light={StaticResource AppTextDarkColor}, Dark=WhiteSmoke}"
                       SelectedIndicatorColor="{StaticResource AppPrimaryColor}"
                       HorizontalOptions="Center"
                       VerticalOptions="End"
                       Margin="0,0,0,20" />
    </Grid>
</ContentPage>