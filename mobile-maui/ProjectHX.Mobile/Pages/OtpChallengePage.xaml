<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.OtpChallengePage"
             Title="OTP Verification">
    <VerticalStackLayout Padding="24" Spacing="12">
        <Label Text="Verify OTP" FontSize="24" FontAttributes="Bold" />
        <Label Text="Enter the 6-digit code sent to your email." TextColor="#6B7280" />

        <Entry Placeholder="Email" Text="{Binding Email}" IsReadOnly="True" />
        <Entry Placeholder="OTP Code" Text="{Binding Code}" Keyboard="Numeric" MaxLength="6" />

        <Label Text="{Binding ErrorMessage}" TextColor="#B91C1C" />
        <Button Text="Verify" Command="{Binding VerifyCommand}" />
    </VerticalStackLayout>
</ContentPage>
