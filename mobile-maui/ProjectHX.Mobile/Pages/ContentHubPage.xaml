<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:ProjectHX.Mobile.ViewModels"
             xmlns:models="clr-namespace:ProjectHX.Mobile.Models.PublicContent"
             x:Class="ProjectHX.Mobile.Pages.ContentHubPage"
             x:DataType="viewModels:ContentHubViewModel"
             Title="Explore"
             BackgroundColor="#FFFFFF">
    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="0">
            <!-- Hero Section -->
            <Border Style="{StaticResource CardStyle}" 
                    Margin="0" Padding="20" 
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,0">
                        <GradientStop Color="#0F172A" Offset="0" />
                        <GradientStop Color="#0EA5E9" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Welcome to the Campaign" FontSize="28" FontAttributes="Bold" TextColor="#FFFFFF" LineBreakMode="WordWrap" />
                    <Label Text="Discover news, events, policy initiatives, and meet the team driving change." 
                           TextColor="#DBEAFE" FontSize="14" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <!-- Error and Loading States -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" 
                             Color="{StaticResource BrandGreen}" Margin="20" />
            <Border IsVisible="{Binding HasErrorMessage}" BackgroundColor="#FEF2F2" 
                   Stroke="#FCA5A5" StrokeThickness="1" Padding="12" Margin="20">
                <Label Text="{Binding ErrorMessage}" TextColor="#991B1B" />
            </Border>

            <!-- Refresh Button -->
            <Button Text="Refresh All Content" Command="{Binding RefreshCommand}" 
                   Margin="20,12" BackgroundColor="#0EA5E9" TextColor="#FFFFFF" 
                   CornerRadius="8" Padding="16,12" />

            <!-- Featured News Section -->
            <VerticalStackLayout Padding="20,20" Spacing="12">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="Featured News" FontSize="20" FontAttributes="Bold" 
                           TextColor="#0F172A" VerticalOptions="Center" />
                    <Button Text="View All" Command="{Binding GoToAllNewsCommand}" 
                           BackgroundColor="#F0F9FF" TextColor="#0284C7" 
                           CornerRadius="6" Padding="12,6" FontSize="12" 
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Featured News Cards -->
                <CollectionView ItemsSource="{Binding FeaturedNews}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:NewsArticleListItemModel">
                            <Border Padding="12" Margin="0,0,0,8" Stroke="#E5E7EB" 
                                   BackgroundColor="#FFFFFF" StrokeThickness="1"
                                   StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="8">
                                    <Border Padding="1" Margin="0" Stroke="#E5E7EB" BackgroundColor="#FFFFFF"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8">
                                        <Image Source="{Binding PrimaryImageUrl}" HeightRequest="140" 
                                          Aspect="AspectFill" IsVisible="{Binding HasPrimaryImage}" />
                                    </Border>
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" 
                                               TextColor="#0F172A" LineBreakMode="TailTruncation" MaxLines="2" />
                                        <Label Text="{Binding Excerpt}" FontSize="12" TextColor="#6B7280" 
                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                        <Label Text="{Binding PublishedDisplay}" FontSize="11" TextColor="#9CA3AF" />
                                    </VerticalStackLayout>
                                    <Button Text="Read" 
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenNewsCommand}"
                                           CommandParameter="{Binding .}"
                                           BackgroundColor="#0EA5E9" TextColor="#FFFFFF" 
                                           CornerRadius="6" Padding="12,6" FontSize="12" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Events Section -->
            <VerticalStackLayout Padding="20,20" Spacing="12" BackgroundColor="#F8FAFC">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="Upcoming Events" FontSize="20" FontAttributes="Bold" 
                           TextColor="#0F172A" VerticalOptions="Center" />
                    <Button Text="View All" Command="{Binding GoToAllEventsCommand}" 
                           BackgroundColor="#F0F9FF" TextColor="#0284C7" 
                           CornerRadius="6" Padding="12,6" FontSize="12" 
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Events Cards -->
                <CollectionView ItemsSource="{Binding UpcomingEvents}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CampaignEventModel">
                            <Border Padding="12" Margin="0,0,0,8" Stroke="#E5E7EB" 
                                   BackgroundColor="#FFFFFF" StrokeThickness="1"
                                   StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="8">
                                    <Image Source="{Binding ImageUrl}" HeightRequest="140" 
                                          Aspect="AspectFill" IsVisible="{Binding HasImage}" />
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" 
                                               TextColor="#0F172A" LineBreakMode="TailTruncation" MaxLines="2" />
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="📅" FontSize="11" />
                                            <Label Text="{Binding DateDisplay}" FontSize="11" TextColor="#6B7280" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="4" IsVisible="{Binding Location, Converter={StaticResource StringToNotEmptyConverter}}">
                                            <Label Text="📍" FontSize="11" />
                                            <Label Text="{Binding Location}" FontSize="11" TextColor="#6B7280" LineBreakMode="TailTruncation" MaxLines="1" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <Button Text="View Event" 
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenEventCommand}"
                                           CommandParameter="{Binding .}"
                                           BackgroundColor="#0EA5E9" TextColor="#FFFFFF" 
                                           CornerRadius="6" Padding="12,6" FontSize="12" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Policy Issues Section -->
            <VerticalStackLayout Padding="20,20" Spacing="12">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="Policy Issues" FontSize="20" FontAttributes="Bold" 
                           TextColor="#0F172A" VerticalOptions="Center" />
                    <Button Text="View All" 
                           BackgroundColor="#F0F9FF" TextColor="#0284C7" 
                           CornerRadius="6" Padding="12,6" FontSize="12" 
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Issues Cards -->
                <CollectionView ItemsSource="{Binding Issues}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:IssueModel">
                            <Border Padding="12" Margin="0,0,0,8" Stroke="#E5E7EB" 
                                   BackgroundColor="#FFFFFF" StrokeThickness="1"
                                   StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="8">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Icon}" FontSize="24" IsVisible="{Binding HasIcon}" 
                                               VerticalOptions="Center" WidthRequest="36" />
                                        <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" 
                                               TextColor="#0F172A" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Summary}" FontSize="12" TextColor="#6B7280" 
                                           LineBreakMode="TailTruncation" MaxLines="2" />
                                    <Button Text="Explore Issue" 
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenIssueCommand}"
                                           CommandParameter="{Binding .}"
                                           BackgroundColor="#0EA5E9" TextColor="#FFFFFF" 
                                           CornerRadius="6" Padding="12,6" FontSize="12" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Campaign Team Section -->
            <VerticalStackLayout Padding="20,20" Spacing="12" BackgroundColor="#F8FAFC">
                <Label Text="Campaign Team" FontSize="20" FontAttributes="Bold" 
                       TextColor="#0F172A" />
                <Label Text="Meet the dedicated leaders driving our vision for a better Kenya." 
                       FontSize="13" TextColor="#6B7280" />

                <!-- Team Members Cards -->
                <CollectionView ItemsSource="{Binding TeamMembers}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CampaignTeamMemberModel">
                            <Border Padding="12" Margin="0,0,0,8" Stroke="#E5E7EB" 
                                   BackgroundColor="#FFFFFF" StrokeThickness="1"
                                   StrokeShape="RoundRectangle 8">
                                <HorizontalStackLayout Spacing="12">
                                    <Image Source="{Binding PhotoUrl}" WidthRequest="56" HeightRequest="56" 
                                          Aspect="AspectFill" IsVisible="{Binding HasPhoto}" />
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Fill">
                                        <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" 
                                               TextColor="#0F172A" />
                                        <Label Text="{Binding Role}" FontSize="12" TextColor="#0EA5E9" FontAttributes="Bold" />
                                        <Label Text="{Binding Bio}" FontSize="11" TextColor="#6B7280" 
                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Footer Spacing -->
            <BoxView HeightRequest="20" Color="Transparent" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
