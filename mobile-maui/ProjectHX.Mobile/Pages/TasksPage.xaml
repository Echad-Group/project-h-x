<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.TasksPage"
             Title="Tasks">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Top section: banner, status, filters, selected-task detail ── -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="14">

                <!-- Hero banner -->
                <Border Style="{StaticResource CardStyle}" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="1,0">
                            <GradientStop Color="#0369A1" Offset="0" />
                            <GradientStop Color="#065F46" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Daily Execution Hub" FontSize="28" FontAttributes="Bold" TextColor="#FFFFFF" />
                        <Label Text="Track tasks and command priorities across your wards." TextColor="#E0F2FE" />
                    </VerticalStackLayout>
                </Border>

                <!-- Busy indicator -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource BrandGreen}" HorizontalOptions="Center" />

                <!-- Error banner -->
                <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasErrorMessage}"
                        BackgroundColor="#FEF2F2" StrokeThickness="1" Stroke="#FCA5A5">
                    <Label Text="{Binding ErrorMessage}" TextColor="#991B1B" />
                </Border>

                <!-- Info banner -->
                <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasInfoMessage}"
                        BackgroundColor="#F0FDF4" StrokeThickness="1" Stroke="#86EFAC">
                    <Label Text="{Binding InfoMessage}" TextColor="#166534" />
                </Border>

                <!-- Filter bar -->
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="All"
                                Command="{Binding SetFilterCommand}" CommandParameter="All"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Text="Pending"
                                Command="{Binding SetFilterCommand}" CommandParameter="Pending"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Text="In Progress"
                                Command="{Binding SetFilterCommand}" CommandParameter="InProgress"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Text="Completed"
                                Command="{Binding SetFilterCommand}" CommandParameter="Completed"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Selected-task detail panel -->
                <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasSelectedTask}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding SelectedTask.Title}" FontAttributes="Bold" FontSize="17" />

                        <HorizontalStackLayout Spacing="8">
                            <Border BackgroundColor="{Binding SelectedTask.StatusColor}"
                                    Padding="6,2" StrokeThickness="0" StrokeShape="RoundRectangle 4">
                                <Label Text="{Binding SelectedTask.StatusDisplay}" TextColor="White" FontSize="12" />
                            </Border>
                            <Label Text="{Binding SelectedTask.Priority}" Style="{StaticResource MutedLabelStyle}" VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Label Text="{Binding SelectedTask.Description}" />
                        <Label Text="{Binding SelectedTask.DeadlineDisplay}" Style="{StaticResource MutedLabelStyle}" />
                        <Label Text="{Binding SelectedTask.LocationSummary}" Style="{StaticResource MutedLabelStyle}"
                               />

                        <!-- Start Task (Pending → InProgress) -->
                        <Button Text="Start Task"
                                Command="{Binding StartTaskCommand}"
                                IsVisible="{Binding SelectedTask.CanStart}" />

                        <!-- Show completion form (InProgress → Completed) -->
                        <Button Text="Mark Complete"
                                Command="{Binding ShowCompletionFormCommand}"
                                IsVisible="{Binding SelectedTask.CanComplete}"
                                IsEnabled="{Binding IsCompletionFormNotVisible}" />

                        <!-- Completion form -->
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding IsCompletionFormVisible}">
                            <Label Text="Completion Notes (optional)" Style="{StaticResource MutedLabelStyle}" />
                            <Editor Text="{Binding CompletionNotes}" Placeholder="Describe what was done..."
                                    MinimumHeightRequest="80" AutoSize="TextChanges" />
                            <Button Text="Submit Completion" Command="{Binding CompleteTaskCommand}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Empty state -->
                  <Label Text="No tasks found." Style="{StaticResource MutedLabelStyle}"
                      HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Task list ── -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Tasks}"
                        Margin="20,0,20,20"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectTaskCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                            <HorizontalStackLayout Spacing="8">
                                <Border BackgroundColor="{Binding StatusColor}"
                                        Padding="5,1" StrokeThickness="0" StrokeShape="RoundRectangle 4">
                                    <Label Text="{Binding StatusDisplay}" TextColor="White" FontSize="11" />
                                </Border>
                                <Label Text="{Binding Priority}" Style="{StaticResource MutedLabelStyle}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding DeadlineDisplay}" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
