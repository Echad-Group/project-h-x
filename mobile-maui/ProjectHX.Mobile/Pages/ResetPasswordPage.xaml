<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.ResetPasswordPage"
             Title="Reset Password">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Border Style="{StaticResource CardStyle}" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,0">
                        <GradientStop Color="#0F766E" Offset="0" />
                        <GradientStop Color="#0E9F6E" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Set New Password" FontSize="28" FontAttributes="Bold" TextColor="#FFFFFF" />
                    <Label Text="Use your reset token and create a strong password." TextColor="#CCFBF1" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Reset Details" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="Paste the reset token from your email if not prefilled." Style="{StaticResource MutedLabelStyle}" />

                    <Border IsVisible="{Binding HasErrorMessage}" BackgroundColor="#FEF2F2" Stroke="#FCA5A5" StrokeThickness="1" Padding="12">
                        <Label Text="{Binding ErrorMessage}" TextColor="#B91C1C" />
                    </Border>
                    <Border IsVisible="{Binding HasInfoMessage}" BackgroundColor="#ECFDF5" Stroke="#6EE7B7" StrokeThickness="1" Padding="12">
                        <Label Text="{Binding InfoMessage}" TextColor="#065F46" />
                    </Border>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

                    <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" IsEnabled="{Binding IsNotBusy}" />
                    <Editor Placeholder="Reset Token" Text="{Binding Token}" AutoSize="TextChanges" HeightRequest="120" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="New Password" Text="{Binding NewPassword}" IsPassword="True" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Confirm New Password" Text="{Binding ConfirmPassword}" IsPassword="True" IsEnabled="{Binding IsNotBusy}" />

                    <Button Text="Reset Password" Command="{Binding SubmitCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Text="Back to Sign In" Command="{Binding GoToLoginCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
