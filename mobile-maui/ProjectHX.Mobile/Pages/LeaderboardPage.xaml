<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.LeaderboardPage"
             Title="Leaderboard">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Border Style="{StaticResource CardStyle}" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,0">
                        <GradientStop Color="#B45309" Offset="0" />
                        <GradientStop Color="#EF4444" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Campaign Leaderboard" FontSize="28" FontAttributes="Bold" TextColor="#FFFFFF" />
                    <Label Text="Track national and regional impact performance." TextColor="#FEF3C7" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Filters" Style="{StaticResource SectionTitleStyle}" />
                    <Entry Placeholder="Scope: National / Region / County" />
                    <Entry Placeholder="Region (optional)" />
                    <Entry Placeholder="County (optional)" />
                    <Button Text="Refresh" Style="{StaticResource SecondaryButtonStyle}" />
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource CardBorder}" Margin="0,4,0,2" />
                    <Label Text="No leaderboard rows found." Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
