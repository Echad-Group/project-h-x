<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.LeaderboardPage"
             Title="Leaderboard">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Border Style="{StaticResource CardStyle}" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,0">
                        <GradientStop Color="#B45309" Offset="0" />
                        <GradientStop Color="#EF4444" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Campaign Leaderboard" FontSize="28" FontAttributes="Bold" TextColor="#FFFFFF" />
                    <Label Text="Track your national and regional impact performance." TextColor="#FEF3C7" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Scope" Style="{StaticResource SectionTitleStyle}" />
                    <Picker Title="Select scope"
                            ItemsSource="{Binding ScopeOptions}"
                            SelectedItem="{Binding SelectedScope}" />
                    <Button Text="Refresh Rank"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource BrandGreen}" HorizontalOptions="Center" />

            <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasErrorMessage}"
                    BackgroundColor="#FEF2F2" StrokeThickness="1" Stroke="#FCA5A5">
                <Label Text="{Binding ErrorMessage}" TextColor="#991B1B" />
            </Border>

            <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasRank}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="My Rank" Style="{StaticResource SectionTitleStyle}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="#FEF3C7" Padding="12"
                                StrokeThickness="0" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding MyRank.RankDisplay}" FontAttributes="Bold"
                                       FontSize="20" TextColor="#92400E" HorizontalOptions="Center" />
                                <Label Text="Overall Rank" Style="{StaticResource MutedLabelStyle}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#F0FDF4" Padding="12"
                                StrokeThickness="0" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding MyRank.PointsDisplay}" FontAttributes="Bold"
                                       FontSize="20" TextColor="#065F46" HorizontalOptions="Center" />
                                <Label Text="Total Points" Style="{StaticResource MutedLabelStyle}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource CardBorder}" />

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="Badge:" Style="{StaticResource MutedLabelStyle}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding MyRank.BadgeTier}" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Title:" Style="{StaticResource MutedLabelStyle}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding MyRank.RecognitionTitle}" />
                        <Label Grid.Row="2" Grid.Column="0" Text="Location:" Style="{StaticResource MutedLabelStyle}" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding MyRank.LocationDisplay}" />
                    </Grid>

                    <Border BackgroundColor="#7C3AED" Padding="8,4" StrokeThickness="0"
                            StrokeShape="RoundRectangle 6" HorizontalOptions="Start"
                            IsVisible="{Binding MyRank.IncentiveTag}">
                        <Label Text="{Binding MyRank.IncentiveTag}" TextColor="White"
                               FontAttributes="Bold" FontSize="13" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}"
                    IsVisible="{Binding HasNoRank}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="No leaderboard rank yet." FontAttributes="Bold" />
                    <Label Text="Complete tasks and grow your network to earn points and appear on the leaderboard."
                           Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
