<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.ProfilePage"
             Title="Profile">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Border Style="{StaticResource CardStyle}" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,0">
                        <GradientStop Color="#067647" Offset="0" />
                        <GradientStop Color="#C35B00" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Member Profile Hub" FontSize="30" FontAttributes="Bold" TextColor="#FFFFFF" />
                    <Label Text="Keep identity, security, and verification data up to date." TextColor="#ECFDF5" />
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding HasErrorMessage}" BackgroundColor="#FEF2F2" Stroke="#FCA5A5" StrokeThickness="1" Padding="12">
                <Label Text="{Binding ErrorMessage}" TextColor="#B91C1C" />
            </Border>
            <Border IsVisible="{Binding HasInfoMessage}" BackgroundColor="#ECFDF5" Stroke="#6EE7B7" StrokeThickness="1" Padding="12">
                <Label Text="{Binding InfoMessage}" TextColor="#065F46" />
            </Border>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Profile Completion" Style="{StaticResource SectionTitleStyle}" />
                    <ProgressBar Progress="{Binding CompletionProgress}" />
                    <Label Text="{Binding CompletionSummary}" Style="{StaticResource MutedLabelStyle}" />
                    <Label Text="Verification Status" FontAttributes="Bold" />
                    <Label Text="{Binding VerificationStatus}" />
                    <Label Text="Voter Card Status" FontAttributes="Bold" />
                    <Label Text="{Binding VoterCardStatus}" />
                    <Label Text="Roles" FontAttributes="Bold" />
                    <Label Text="{Binding RolesSummary}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Identity &amp; Verification" Style="{StaticResource SectionTitleStyle}" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Image Source="{Binding ProfilePhotoUrl}" HeightRequest="120" WidthRequest="120" Aspect="AspectFill" IsVisible="{Binding HasProfilePhoto}" HorizontalOptions="Start" />
                    <Label Text="Upload your profile photo and verification documents to match web onboarding requirements." Style="{StaticResource MutedLabelStyle}" />
                    <Button Text="Upload Profile Photo" Command="{Binding UploadProfilePhotoCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Text="Delete Profile Photo" Command="{Binding DeleteProfilePhotoCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />
                    <Label Text="{Binding NidaDocumentStatus}" TextColor="#374151" />
                    <Button Text="Upload NIDA Document" Command="{Binding UploadNidaDocumentCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />
                    <Label Text="{Binding VoterCardDocumentStatus}" TextColor="#374151" />
                    <Button Text="Upload Voter Card" Command="{Binding UploadVoterCardDocumentCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />
                    <Label Text="{Binding SelfieDocumentStatus}" TextColor="#374151" />
                    <Button Text="Upload Verification Selfie" Command="{Binding UploadSelfieDocumentCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Profile Details" Style="{StaticResource SectionTitleStyle}" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Entry Placeholder="Email" Text="{Binding Email}" IsReadOnly="True" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="First Name" Text="{Binding FirstName}" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Last Name" Text="{Binding LastName}" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Phone Number" Text="{Binding PhoneNumber}" Keyboard="Telephone" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Location" Text="{Binding Location}" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Website" Text="{Binding Website}" Keyboard="Url" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Twitter" Text="{Binding Twitter}" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Facebook" Text="{Binding Facebook}" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="LinkedIn" Text="{Binding LinkedIn}" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="National ID Number" Text="{Binding NationalIdNumber}" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Voter Card Number" Text="{Binding VoterCardNumber}" IsEnabled="{Binding IsNotBusy}" />
                    <Editor Placeholder="Bio" Text="{Binding Bio}" AutoSize="TextChanges" HeightRequest="120" IsEnabled="{Binding IsNotBusy}" />
                    <Button Text="Save Profile" Command="{Binding SaveProfileCommand}" IsEnabled="{Binding IsNotBusy}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Account Security" Style="{StaticResource SectionTitleStyle}" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Entry Placeholder="New Email" Text="{Binding NewEmail}" Keyboard="Email" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Current Password For Email Change" Text="{Binding EmailPassword}" IsPassword="True" IsEnabled="{Binding IsNotBusy}" />
                    <Button Text="Update Email" Command="{Binding UpdateEmailCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />

                    <Entry Placeholder="Current Password" Text="{Binding CurrentPassword}" IsPassword="True" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="New Password" Text="{Binding NewPassword}" IsPassword="True" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Confirm New Password" Text="{Binding ConfirmPassword}" IsPassword="True" IsEnabled="{Binding IsNotBusy}" />
                    <Button Text="Change Password" Command="{Binding ChangePasswordCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Session" Style="{StaticResource SectionTitleStyle}" />
            <Button Text="Log Out" Command="{Binding LogoutCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />

            <Label Text="Danger Zone" Style="{StaticResource SectionTitleStyle}" TextColor="#991B1B" />
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Entry Placeholder="Password To Delete Account" Text="{Binding DeletePassword}" IsPassword="True" IsEnabled="{Binding IsNotBusy}" />
                    <Button Text="Delete Account" Command="{Binding DeleteAccountCommand}" Style="{StaticResource DangerButtonStyle}" IsEnabled="{Binding IsNotBusy}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
