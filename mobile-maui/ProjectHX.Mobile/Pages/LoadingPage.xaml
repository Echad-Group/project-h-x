<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="ProjectHX.Mobile.Pages.LoadingPage">
	<VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
		<Image Source="new_kenya_2.png" 
				HeightRequest="185"
				Aspect="AspectFit" />

		<ActivityIndicator IsRunning="True" IsVisible="True" Color="{StaticResource BrandGreen}" />

		<Label x:Name="LoadingText"
			   Text="" 
			   FontSize="16"
			   HorizontalOptions="Center" 
			   TextColor="{AppThemeBinding Light={StaticResource AppTextDarkColor}, Dark=WhiteSmoke}"
			   Margin="0,10"/>

	</VerticalStackLayout>
</ContentPage>