<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.LoginPage"
             Title="Sign In">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="Project H Mobile" FontSize="26" FontAttributes="Bold" />
            <Label Text="Field operations sign in" TextColor="#6B7280" />

            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />
            <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" />

            <Label Text="{Binding ErrorMessage}" TextColor="#B91C1C" />
            <Button Text="Sign In" Command="{Binding SignInCommand}" />
            <Button Text="Create Account" Command="{Binding GoToRegisterCommand}" BackgroundColor="#E5E7EB" TextColor="#111827" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
