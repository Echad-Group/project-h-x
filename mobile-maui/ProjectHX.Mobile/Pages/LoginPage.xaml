<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.LoginPage"
             Title=""
            Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24" Margin="0, 56, 0, 0">
            <Border Style="{StaticResource CardStyle}" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,0">
                        <GradientStop Color="#067647" Offset="0" />
                        <GradientStop Color="#C35B00" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Project H X" FontSize="12" TextColor="#D1FAE5" />
                    <Label Text="Member Sign In" FontSize="28" FontAttributes="Bold" TextColor="#FFFFFF" />
                    <Label Text="Access dashboard, tasks, inbox, and profile tools." TextColor="#ECFDF5" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Welcome Back" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="Use your account credentials to continue." Style="{StaticResource MutedLabelStyle}" />

                    <Border IsVisible="{Binding HasErrorMessage}" BackgroundColor="#FEF2F2" Stroke="#FCA5A5" StrokeThickness="1" Padding="12">
                        <Label Text="{Binding ErrorMessage}" TextColor="#B91C1C" />
                    </Border>
                    <Border IsVisible="{Binding HasInfoMessage}" BackgroundColor="#ECFDF5" Stroke="#6EE7B7" StrokeThickness="1" Padding="12">
                        <Label Text="{Binding InfoMessage}" TextColor="#065F46" />
                    </Border>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

                    <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" IsEnabled="{Binding IsNotBusy}" />
                    <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" IsEnabled="{Binding IsNotBusy}" />

                    <Button Text="Sign In" Command="{Binding SignInCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Text="Forgot Password" Command="{Binding GoToForgotPasswordCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Text="Create Account" Command="{Binding GoToRegisterCommand}" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="{Binding IsNotBusy}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
