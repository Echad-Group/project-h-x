<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.ForgotPasswordPage"
             Title="Forgot Password">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="Forgot Password" FontSize="26" FontAttributes="Bold" />
            <Label Text="Request password reset instructions for your account." TextColor="#6B7280" />

            <Border IsVisible="{Binding HasErrorMessage}" BackgroundColor="#FEF2F2" Stroke="#FCA5A5" StrokeThickness="1" Padding="12">
                <Label Text="{Binding ErrorMessage}" TextColor="#B91C1C" />
            </Border>
            <Border IsVisible="{Binding HasInfoMessage}" BackgroundColor="#ECFDF5" Stroke="#6EE7B7" StrokeThickness="1" Padding="12">
                <Label Text="{Binding InfoMessage}" TextColor="#065F46" />
            </Border>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" IsEnabled="{Binding IsNotBusy}" />

            <Button Text="Send Reset Instructions" Command="{Binding SubmitCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Text="I Have A Reset Token" Command="{Binding GoToResetCommand}" BackgroundColor="#E5E7EB" TextColor="#111827" IsEnabled="{Binding IsNotBusy}" />
            <Button Text="Back to Sign In" Command="{Binding GoToLoginCommand}" BackgroundColor="#E5E7EB" TextColor="#111827" IsEnabled="{Binding IsNotBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
