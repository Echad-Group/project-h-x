<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.RegisterPage"
             Title="Create Account">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="Create Account" FontSize="26" FontAttributes="Bold" />
            <Label Text="Register and verify OTP to activate your account." TextColor="#6B7280" />

            <Entry Placeholder="First Name" Text="{Binding FirstName}" />
            <Entry Placeholder="Last Name" Text="{Binding LastName}" />
            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />
            <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" />
            <Entry Placeholder="Confirm Password" Text="{Binding ConfirmPassword}" IsPassword="True" />

            <Label Text="{Binding ErrorMessage}" TextColor="#B91C1C" />
            <Label Text="{Binding InfoMessage}" TextColor="#065F46" />

            <Button Text="Register" Command="{Binding RegisterCommand}" />
            <Button Text="Back to Sign In" Command="{Binding GoToLoginCommand}" BackgroundColor="#E5E7EB" TextColor="#111827" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
