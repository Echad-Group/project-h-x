<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.Pages.EventDetailPage"
             Title="Event Detail">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource BrandGreen}" />
            <Border IsVisible="{Binding HasErrorMessage}" BackgroundColor="#FEF2F2" Stroke="#FCA5A5" StrokeThickness="1" Padding="12">
                <Label Text="{Binding ErrorMessage}" TextColor="#991B1B" />
            </Border>
            <Border IsVisible="{Binding HasInfoMessage}" BackgroundColor="#ECFDF5" Stroke="#6EE7B7" StrokeThickness="1" Padding="12">
                <Label Text="{Binding InfoMessage}" TextColor="#065F46" />
            </Border>

            <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasEvent}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding EventItem.Title}" FontSize="24" FontAttributes="Bold" />
                    <Label Text="{Binding EventItem.DateDisplay}" Style="{StaticResource MutedLabelStyle}" />
                    <Label Text="{Binding EventItem.Location}" Style="{StaticResource MutedLabelStyle}" />
                    <Label Text="{Binding EventItem.Description}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardStyle}" IsVisible="{Binding HasEvent}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="RSVP" Style="{StaticResource SectionTitleStyle}" />
                    <Entry Placeholder="Name" Text="{Binding AttendeeName}" />
                    <Entry Placeholder="Email" Text="{Binding AttendeeEmail}" Keyboard="Email" />
                    <Entry Placeholder="Phone (optional)" Text="{Binding AttendeePhone}" Keyboard="Telephone" />
                    <Entry Placeholder="Guest count" Text="{Binding GuestCount}" Keyboard="Numeric" />
                    <Editor Placeholder="Special requirements" Text="{Binding SpecialRequirements}" AutoSize="TextChanges" HeightRequest="90" />
                    <Button Text="Submit RSVP" Command="{Binding SubmitRsvpCommand}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
