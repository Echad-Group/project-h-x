<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectHX.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBackground">#F3F4F6</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="CardBorder">#E5E7EB</Color>
            <Color x:Key="MutedText">#6B7280</Color>
            <Color x:Key="BodyText">#111827</Color>
            <Color x:Key="BrandGreen">#067647</Color>
            <Color x:Key="BrandGreenDark">#065F46</Color>
            <Color x:Key="BrandOrange">#C35B00</Color>
            <Color x:Key="DangerRed">#C81E1E</Color>




            <!-- App Color Resources -->
            <Color x:Key="AppPrimaryColor">#FFBE26</Color>
            <Color x:Key="AppSecondaryColor">#FF2B24</Color>
            <Color x:Key="AppTertiaryColor">#AFFF24</Color>
            <Color x:Key="AppUtinaryColor">#F60076</Color>
            <Color x:Key="AppDenaryColor">#D3189E</Color>
            <Color x:Key="AppAccentColor">#24FF2B</Color>
            <Color x:Key="AppPrimaryHoverColor">#E4A000</Color>
            <Color x:Key="AppSecondaryHoverColor">#E40800</Color>
            <Color x:Key="AppTertiaryHoverColor">#84D000</Color>
            <Color x:Key="AppUtinaryHoverColor">#D20065</Color>
            <Color x:Key="AppDenaryHoverColor">#B51487</Color>
            <Color x:Key="AppAccentHoverColor">#00BB06</Color>
            <Color x:Key="AppPrimaryFocusColor">#A67400</Color>
            <Color x:Key="AppSecondaryFocusColor">#A60600</Color>
            <Color x:Key="AppTertiaryFocusColor">#5C9100</Color>
            <Color x:Key="AppUtinaryFocusColor">#AF0055</Color>
            <Color x:Key="AppDenaryFocusColor">#971171</Color>
            <Color x:Key="AppAccentFocusColor">#007D04</Color>
            <Color x:Key="AppTextBlackColor">#000000</Color>
            <Color x:Key="AppTextDarkColor">#333333</Color>
            <Color x:Key="AppTextCharcoalColor">#4A4A4A</Color>
            <Color x:Key="AppTextSlateGrayColor">#2E2E2E</Color>
            <Color x:Key="AppTextNavyBlueColor">#000080</Color>



            <!-- Define the accent color -->
            <Color x:Key="AccentColor">#25472c</Color>
            <!-- Use any color you like -->

            <Color x:Key="Primary">#25472c</Color>
            <Color x:Key="PrimaryDark">#437F4F</Color>
            <Color x:Key="PrimaryDarkText">#2b823b</Color>
            <Color x:Key="Secondary">#2b823b</Color>
            <Color x:Key="SecondaryDarkText">#3DB854</Color>
            <Color x:Key="Tertiary">#f9f871</Color>

            <Color x:Key="AppOrange">#FD5E0F</Color>
            <Color x:Key="AppLightDockOrange">#F9C5AD</Color>
            <Color x:Key="AppTextColorDark">White</Color>

            <Color x:Key="BackgroundGreen">#2b823b</Color>
            <Color x:Key="DarkGreen">#25472c</Color>
            <Color x:Key="LogoGreen">#93c242</Color>

            <Color x:Key="DarkBackground">#17171a</Color>
            <Color x:Key="LightOnDarkBackground">#C3C3C3</Color>
            <Color x:Key="LightBackground">#F2F2F2</Color>
            <Color x:Key="DarkOnLightBackground">#0D0D0D</Color>

            <Color x:Key="LightSecondaryBackground">#E0E0E0</Color>
            <Color x:Key="DarkSecondaryBackground">#222228</Color>

            <Color x:Key="White">White</Color>
            <Color x:Key="Black">Black</Color>
            <Color x:Key="Magenta">#D600AA</Color>
            <Color x:Key="MidnightBlue">#190649</Color>
            <Color x:Key="OffBlack">#1f1f1f</Color>

            <Color x:Key="Gray100">#E1E1E1</Color>
            <Color x:Key="Gray200">#C8C8C8</Color>
            <Color x:Key="Gray300">#ACACAC</Color>
            <Color x:Key="Gray400">#919191</Color>
            <Color x:Key="Gray500">#6E6E6E</Color>
            <Color x:Key="Gray600">#404040</Color>
            <Color x:Key="Gray900">#212121</Color>
            <Color x:Key="Gray950">#141414</Color>

            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
            <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
            <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
            <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
            <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

            <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
            <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
            <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
            <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
            <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
            <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
            <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
            <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>




            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource BodyText}" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="PageTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="#0F172A" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="#0F172A" />
            </Style>

            <Style x:Key="MutedLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource MutedText}" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="Stroke" Value="{StaticResource CardBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="14" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="#FFFFFF" />
                <Setter Property="TextColor" Value="#111827" />
                <Setter Property="PlaceholderColor" Value="#9CA3AF" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style TargetType="Editor">
                <Setter Property="BackgroundColor" Value="#FFFFFF" />
                <Setter Property="TextColor" Value="#111827" />
                <Setter Property="PlaceholderColor" Value="#9CA3AF" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource BrandGreen}" />
                <Setter Property="TextColor" Value="#FFFFFF" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#F3F4F6" />
                <Setter Property="TextColor" Value="#111827" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource DangerRed}" />
                <Setter Property="TextColor" Value="#FFFFFF" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
